# Dependencies (re-installed inside Docker) — ** matches any depth
**/node_modules

# Next.js build output (built inside Docker)
.next
apps/frontend/.next

# Env files — never bake secrets into images
.env
.env.*
!.env.example

# Dev / local artifacts
npm-debug.log*
*.log
.DS_Store
coverage
.nyc_output

# Git
.git
.gitignore

# Docs / scripts not needed in image
README.md
TESTING.md
docs/
k8s/
scripts/
.superpowers
